# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key for admin testimonial moderation.
# Required in production if you want /dashboard to approve, unpublish, or delete testimonials.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails allowed to use moderation endpoints with Supabase auth.
ADMIN_EMAILS=

# Optional fallback admin key accepted by /api/testimonials admin endpoints.
# Keep this secret and set it only in your hosting provider environment variables.
TESTIMONIAL_ADMIN_KEY=

# Development only: set to 1 if you intentionally want JSON-file testimonial fallback in production.
ALLOW_LOCAL_TESTIMONIAL_FALLBACK=0
